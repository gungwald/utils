#!/bin/sh

# After running this to load the arp cache, "arp -a" can be run to print out
# the cache which includes ethernet (mac) addresses, hopefully.

# Starting from 50 because my DHCP server doesn't allocated anything below that.
for i in $(seq 50 254)
do
  echo Pinging 192.168.1.$i
  ping -c 1 -w 1 192.168.1.$i | grep "bytes from"
done
    
